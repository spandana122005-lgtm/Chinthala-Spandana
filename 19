# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution:
    def swapPairs(self, head):
        dummy = ListNode(0)
        dummy.next = head
        prev = dummy
        
        while prev.next and prev.next.next:
            first = prev.next
            second = prev.next.next
            
            # Reassign pointers to swap 'first' and 'second'
            first.next = second.next
            second.next = first
            prev.next = second
            
            # Advance prev two steps forward
            prev = first
            
        return dummy.next
