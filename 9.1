class Solution(object):
    def myAtoi(self, s):
        """
        :type s: str
        :rtype: int
        """
        i = 0
        n = len(s)

        # Step 1: Skip leading whitespaces
        while i < n and s[i] == ' ':
            i += 1

        # Step 2: Check sign
        sign = 1
        if i < n and (s[i] == '+' or s[i] == '-'):
            if s[i] == '-':
                sign = -1
            i += 1

        # Step 3: Convert digits
        num = 0
        while i < n and s[i].isdigit():
            digit = int(s[i])

            # Check overflow
            if num > (2**31 - 1) // 10 or (
                num == (2**31 - 1) // 10 and digit > 7
            ):
                return -2**31 if sign == -1 else 2**31 - 1

            num = num * 10 + digit
            i += 1

        return sign * num
