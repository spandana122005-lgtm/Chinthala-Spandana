class Solution:
    def romanToInt(self, s: str) -> int:
        special = {
            "IV": 4,
            "IX": 9,
            "XL": 40,
            "XC": 90,
            "CD": 400,
            "CM": 900
        }

        normal = {
            "I": 1,
            "V": 5,
            "X": 10,
            "L": 50,
            "C": 100,
            "D": 500,
            "M": 1000
        }

        total = 0
        i = 0

        while i < len(s):
            # check two-character special cases
            if i + 1 < len(s) and s[i:i+2] in special:
                total += special[s[i:i+2]]
                i += 2
            else:
                total += normal[s[i]]
                i += 1

        return total


# Example test
obj = Solution()
print(obj.romanToInt("III"))      # 3
print(obj.romanToInt("LVIII"))    # 58
print(obj.romanToInt("MCMXCIV"))  # 1994
