class Solution:
    def romanToInt(self, s: str) -> int:
        roman = {
            'I': 1,
            'V': 5,
            'X': 10,
            'L': 50,
            'C': 100,
            'D': 500,
            'M': 1000
        }

        total = 0
        prev = 0

        for ch in reversed(s):
            value = roman[ch]

            if value < prev:
                total -= value
            else:
                total += value

            prev = value

        return total


# Example test
obj = Solution()
print(obj.romanToInt("III"))      # 3
print(obj.romanToInt("LVIII"))    # 58
print(obj.romanToInt("MCMXCIV"))  # 1994
